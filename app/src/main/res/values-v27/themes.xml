<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.HireHub" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@color/background</item>

        <!-- Updated status bar color to match your primary color -->
        <item name="android:statusBarColor">@color/primary</item>

        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowAnimationStyle">@style/WindowAnimationStyle</item>

        <!-- Make status bar icons light (white) for better contrast -->
        <item name="android:windowLightStatusBar">false</item>

        <!-- Ensure content fits under status bar -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>