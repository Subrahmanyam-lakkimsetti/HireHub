<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    android:foreground="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="4dp"
        android:layout_marginVertical="3dp"
        android:padding="16dp">

        <!-- Row 1: Title + Save icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvJobTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginEnd="8dp"
                android:text="Software Engineer" />

            <ImageView
                android:id="@+id/ivSave"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_bookmark_outline"
                android:padding="2dp"
                app:tint="@color/primary" />

        </LinearLayout>

        <!-- Row 2: Company -->
        <TextView
            android:id="@+id/tvCompany"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:text="Company Name" />

        <!-- Row 3: Location + Salary -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍"
                android:textSize="12sp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:text="Remote" />

            <TextView
                android:id="@+id/tvSalary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/success"
                android:textSize="12sp"
                android:text="" />

        </LinearLayout>

        <!-- Row 4: Matched skills pills -->
        <HorizontalScrollView
            android:id="@+id/scrollMatchedSkills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/layoutMatchedSkills"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <!-- Row 5: Bottom row — source badge + match score -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical">

            <!-- Source badge -->
            <TextView
                android:id="@+id/tvSource"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:text="remotive"
                android:background="@drawable/bg_chip_rounded"
                android:backgroundTint="@color/primary" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Match score badge -->
            <TextView
                android:id="@+id/tvMatchScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:text="85% Match"
                android:background="@drawable/bg_chip_rounded"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>